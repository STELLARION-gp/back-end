        {
            "name": "Update User Profile",
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{firebase_token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"display_name\": \"JohnAstro\",\n  \"profile_data\": {\n    \"bio\": \"Passionate astronomy enthusiast with 5 years of experience\",\n    \"location\": \"San Francisco, CA\",\n    \"website\": \"https://johndoe.com\",\n    \"github\": \"johndoe\",\n    \"linkedin\": \"john-doe\",\n    \"astronomy_experience\": \"intermediate\",\n    \"favorite_astronomy_fields\": [\"Astrophysics\", \"Planetary Science\"],\n    \"telescope_owned\": true,\n    \"telescope_type\": \"Celestron NexStar 8SE\",\n    \"observation_experience\": 3,\n    \"certifications\": [\"Amateur Radio License\"],\n    \"achievements\": [\"First astrophoto\", \"100 nights of observation\"]\n  },\n  \"role_specific_data\": {\n    \"learning_goals\": [\"Master astrophotography\", \"Build own telescope\"],\n    \"current_projects\": [\"M31 imaging series\", \"Solar observation log\"]\n  }\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/user/profile",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "user",
                        "profile"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Upload Profile Picture",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{firebase_token}}"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "avatar",
                            "type": "file",
                            "src": "path/to/your/profile-picture.jpg"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/api/user/profile/avatar",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "user",
                        "profile",
                        "avatar"
                    ]
                }
            },
            "response": []
        },
